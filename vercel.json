        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/diary/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/saju/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/saju/" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/saju/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    },
    {
      "source": "/branding-coach/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/branding-coach/" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/branding-coach/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    },
    {
      "source": "/roleplay/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/roleplay/" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/roleplay/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    },
    {
      "source": "/library/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/library/" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/library/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
